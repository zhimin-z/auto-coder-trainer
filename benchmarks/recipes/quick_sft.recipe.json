{
  "id": "recipe-benchmark-quick-sft",
  "name": "Quick SFT Benchmark (Minimal Validation)",
  "version": "1.0",
  "source_papers": [],
  "model": {
    "base": "Qwen/Qwen2.5-Coder-0.5B",
    "size": "0.5B",
    "adapter": "lora"
  },
  "dataset": {
    "sources": [
      {
        "name": "swe-bench-trajectories",
        "path": "bigcode/swe-bench-trajectories",
        "mix_weight": 1.0
      }
    ],
    "filters": [
      { "type": "quality_score", "params": { "min_score": 0.7 } }
    ],
    "total_samples": 100
  },
  "trainer": {
    "type": "sft",
    "backend": "trl",
    "params": {
      "lr": 2e-5,
      "epochs": 1,
      "batch_size": 2,
      "gradient_accumulation_steps": 1,
      "warmup_ratio": 0.1,
      "max_seq_length": 512
    }
  },
  "eval": {
    "benchmarks": ["humaneval"],
    "metrics": ["pass@1"],
    "seeds": [42]
  },
  "ablation": [],
  "budget": {
    "max_gpu_hours": 1,
    "gpu_type": "any",
    "max_cost_usd": 2
  }
}
