{
  "id": "recipe-exp10-lora-vs-full",
  "name": "Exp 10: LoRA vs full-parameter on 7B GRPO",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-10"],
  "model": {
    "base": "Qwen/Qwen2.5-7B-Instruct",
    "size": "7B",
    "adapter": "lora"
  },
  "dataset": {
    "sources": [
      {
        "name": "gsm8k",
        "path": "openai/gsm8k",
        "mix_weight": 1.0
      }
    ],
    "total_samples": 8000
  },
  "trainer": {
    "type": "grpo",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-5,
      "epochs": 3,
      "train_batch_size": 32,
      "ppo_mini_batch_size": 16,
      "ppo_micro_batch_size": 2,
      "ppo_epochs": 1,
      "max_prompt_length": 512,
      "max_response_length": 1024,
      "group_size": 8,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.001,
      "use_kl_loss": true,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.4,
      "rollout_tp_size": 1,
      "lora_rank": 16
    }
  },
  "ablation": [
    {
      "name": "training_mode",
      "variable": "model.adapter",
      "values": ["full", "lora"]
    },
    {
      "name": "lora_rank_sweep",
      "variable": "trainer.params.lora_rank",
      "values": [8, 16, 32]
    }
  ],
  "eval": {
    "benchmarks": [],
    "metrics": ["reward_mean", "max_memory_gb", "training_speed", "reasoning_quality"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 96,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
