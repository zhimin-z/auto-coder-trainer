{
  "id": "recipe-exp19-tinyzero-replication",
  "name": "Exp 19: TinyZero original replication (Qwen2.5-3B + Countdown + PPO, ~$30)",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-19"],
  "model": {
    "base": "Qwen/Qwen2.5-3B",
    "size": "3B",
    "adapter": "full"
  },
  "dataset": {
    "sources": [
      {
        "name": "countdown",
        "path": "Jiayi-Pan/Countdown-Tasks-3to4",
        "mix_weight": 1.0
      }
    ],
    "total_samples": 8000
  },
  "trainer": {
    "type": "rl",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-6,
      "epochs": 15,
      "train_batch_size": 256,
      "ppo_mini_batch_size": 64,
      "ppo_micro_batch_size": 8,
      "ppo_epochs": 1,
      "max_prompt_length": 256,
      "max_response_length": 1024,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.001,
      "use_kl_loss": false,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.4,
      "rollout_tp_size": 1,
      "critic_lr": 1e-5,
      "critic_micro_batch_size": 8,
      "custom_reward_function": "scripts/reward_countdown.py:compute_score"
    }
  },
  "eval": {
    "benchmarks": [],
    "metrics": ["countdown_reward_mean", "cost_per_pct_accuracy_usd"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 24,
    "max_cost_usd": 30,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
