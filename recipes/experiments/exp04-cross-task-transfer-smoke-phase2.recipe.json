{
  "id": "recipe-exp04-cross-task-transfer-smoke-phase2",
  "name": "Exp 04 (smoke phase 2): GRPO + GSM8K 0.5B — resumes from phase 1's Countdown checkpoint",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-4"],
  "model": {
    "base": "Qwen/Qwen2.5-0.5B",
    "size": "0.5B",
    "adapter": "full"
  },
  "dataset": {
    "sources": [
      {
        "name": "gsm8k",
        "path": "openai/gsm8k",
        "mix_weight": 1.0
      }
    ],
    "total_samples": 64
  },
  "trainer": {
    "type": "grpo",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-6,
      "epochs": 1,
      "total_training_steps": 8,
      "train_batch_size": 8,
      "val_batch_size": 8,
      "ppo_mini_batch_size": 8,
      "ppo_micro_batch_size": 4,
      "ppo_epochs": 1,
      "max_prompt_length": 256,
      "max_response_length": 256,
      "group_size": 4,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.001,
      "use_kl_loss": true,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.3,
      "rollout_tp_size": 1,
      "save_freq": -1,
      "test_freq": -1
    }
  },
  "eval": {
    "benchmarks": [],
    "metrics": ["gsm8k_reward_mean"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 1,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
