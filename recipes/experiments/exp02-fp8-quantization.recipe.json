{
  "id": "recipe-exp02-fp8-quantization",
  "name": "Exp 02: FP8 quantization vs BF16 on GRPO/GSM8K",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-2"],
  "model": {
    "base": "Qwen/Qwen2.5-7B-Instruct",
    "size": "7B",
    "adapter": "full"
  },
  "dataset": {
    "sources": [
      {
        "name": "gsm8k",
        "path": "openai/gsm8k",
        "mix_weight": 1.0
      }
    ],
    "total_samples": 8000
  },
  "trainer": {
    "type": "grpo",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-6,
      "epochs": 3,
      "train_batch_size": 64,
      "ppo_mini_batch_size": 32,
      "ppo_micro_batch_size": 4,
      "ppo_epochs": 1,
      "max_prompt_length": 512,
      "max_response_length": 1024,
      "group_size": 8,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.001,
      "use_kl_loss": true,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.4,
      "rollout_tp_size": 1,
      "fp8_rollout": true,
      "fp8_actor": false
    }
  },
  "ablation": [
    {
      "name": "precision_mode",
      "variable": "trainer.params.fp8_rollout",
      "values": [false, true]
    },
    {
      "name": "fp8_e2e",
      "variable": "trainer.params.fp8_actor",
      "values": [false, true]
    }
  ],
  "eval": {
    "benchmarks": [],
    "metrics": ["reward_mean", "samples_per_sec", "max_memory_gb"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 96,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
