{
  "id": "recipe-exp08-rollout-n",
  "name": "Exp 08: GRPO rollout n (group_size) sweep",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-8"],
  "model": {
    "base": "Qwen/Qwen2.5-3B-Instruct",
    "size": "3B",
    "adapter": "full"
  },
  "dataset": {
    "sources": [
      {
        "name": "gsm8k",
        "path": "openai/gsm8k",
        "mix_weight": 1.0
      }
    ],
    "total_samples": 8000
  },
  "trainer": {
    "type": "grpo",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-6,
      "epochs": 3,
      "train_batch_size": 32,
      "ppo_mini_batch_size": 16,
      "ppo_micro_batch_size": 4,
      "ppo_epochs": 1,
      "max_prompt_length": 512,
      "max_response_length": 1024,
      "group_size": 8,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.001,
      "use_kl_loss": true,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.4,
      "rollout_tp_size": 1
    }
  },
  "ablation": [
    {
      "name": "rollout_n_sweep",
      "variable": "trainer.params.group_size",
      "values": [2, 4, 8, 16]
    }
  ],
  "eval": {
    "benchmarks": [],
    "metrics": ["reward_mean", "samples_per_sec", "compute_per_step_seconds"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 72,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
