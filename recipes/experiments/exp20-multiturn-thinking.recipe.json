{
  "id": "recipe-exp20-multiturn-thinking",
  "name": "Exp 20: Multi-turn thinking retention (does <think> persist across turns?)",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-20"],
  "model": {
    "base": "Qwen/Qwen2.5-3B-Instruct",
    "size": "3B",
    "adapter": "full"
  },
  "dataset": {
    "sources": [
      {
        "name": "gsm8k",
        "path": "openai/gsm8k",
        "mix_weight": 1.0
      }
    ],
    "total_samples": 5000
  },
  "trainer": {
    "type": "grpo",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-6,
      "epochs": 3,
      "train_batch_size": 32,
      "ppo_mini_batch_size": 16,
      "ppo_micro_batch_size": 4,
      "ppo_epochs": 1,
      "max_prompt_length": 512,
      "max_response_length": 1024,
      "group_size": 8,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.001,
      "use_kl_loss": true,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.4,
      "rollout_tp_size": 1,
      "training_data_format": "single_turn"
    }
  },
  "ablation": [
    {
      "name": "training_format",
      "variable": "trainer.params.training_data_format",
      "values": ["single_turn", "multiturn", "thinking_reward", "system_prompt"]
    }
  ],
  "eval": {
    "benchmarks": [],
    "metrics": ["think_tag_rate_turn1", "think_tag_rate_turn5", "think_quality_decay", "answer_accuracy_decay"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 72,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
