{
  "id": "recipe-exp13-one-shot-rlvr",
  "name": "Exp 13: 1-shot RLVR — minimum sample efficiency",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-13"],
  "model": {
    "base": "Qwen/Qwen2.5-1.5B-Instruct",
    "size": "1.5B",
    "adapter": "full"
  },
  "dataset": {
    "sources": [
      {
        "name": "gsm8k",
        "path": "openai/gsm8k",
        "mix_weight": 1.0
      }
    ],
    "total_samples": 1
  },
  "trainer": {
    "type": "grpo",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-6,
      "epochs": 100,
      "train_batch_size": 1,
      "ppo_mini_batch_size": 1,
      "ppo_micro_batch_size": 1,
      "ppo_epochs": 1,
      "max_prompt_length": 512,
      "max_response_length": 1024,
      "group_size": 16,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.001,
      "use_kl_loss": true,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.4,
      "rollout_tp_size": 1
    }
  },
  "ablation": [
    {
      "name": "n_samples_sweep",
      "variable": "dataset.total_samples",
      "values": [1, 2, 5, 10, 50, 100]
    }
  ],
  "eval": {
    "benchmarks": [],
    "metrics": ["reward_mean", "generalization_score"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 48,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
