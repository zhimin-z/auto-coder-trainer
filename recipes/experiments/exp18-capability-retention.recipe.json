{
  "id": "recipe-exp18-capability-retention",
  "name": "Exp 18: Base capability retention after RL (MMLU/HellaSwag/HumanEval)",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-18"],
  "model": {
    "base": "Qwen/Qwen2.5-3B-Instruct",
    "size": "3B",
    "adapter": "full"
  },
  "dataset": {
    "sources": [
      {
        "name": "gsm8k",
        "path": "openai/gsm8k",
        "mix_weight": 0.8
      },
      {
        "name": "sft_replay",
        "path": "Open-Orca/OpenOrca",
        "mix_weight": 0.2
      }
    ],
    "total_samples": 8000
  },
  "trainer": {
    "type": "grpo",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-6,
      "epochs": 3,
      "train_batch_size": 32,
      "ppo_mini_batch_size": 16,
      "ppo_micro_batch_size": 4,
      "ppo_epochs": 1,
      "max_prompt_length": 512,
      "max_response_length": 1024,
      "group_size": 8,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.01,
      "use_kl_loss": true,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.4,
      "rollout_tp_size": 1,
      "mitigation_strategy": "kl_regularize"
    }
  },
  "ablation": [
    {
      "name": "mitigation_strategy",
      "variable": "trainer.params.mitigation_strategy",
      "values": ["none", "kl_regularize", "sft_mixin", "replay_buffer"]
    }
  ],
  "eval": {
    "benchmarks": ["humaneval", "mmlu", "hellaswag", "truthfulqa"],
    "metrics": ["base_retention_pct", "gsm8k_gain_pct", "regression_max_pct"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 120,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
