{
  "id": "recipe-exp03-data-scaling",
  "name": "Exp 03: GRPO data scaling law (100→8K samples)",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-3"],
  "model": {
    "base": "Qwen/Qwen2.5-3B-Instruct",
    "size": "3B",
    "adapter": "full"
  },
  "dataset": {
    "sources": [
      {
        "name": "gsm8k",
        "path": "openai/gsm8k",
        "mix_weight": 1.0
      }
    ],
    "total_samples": 1000
  },
  "trainer": {
    "type": "grpo",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-6,
      "epochs": 15,
      "train_batch_size": 32,
      "ppo_mini_batch_size": 16,
      "ppo_micro_batch_size": 4,
      "ppo_epochs": 1,
      "max_prompt_length": 512,
      "max_response_length": 1024,
      "group_size": 8,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.001,
      "use_kl_loss": true,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.4,
      "rollout_tp_size": 1
    }
  },
  "ablation": [
    {
      "name": "data_size_sweep",
      "variable": "dataset.total_samples",
      "values": [100, 500, 1000, 2000, 5000, 8000]
    }
  ],
  "eval": {
    "benchmarks": [],
    "metrics": ["reward_mean", "cot_emergence_rate"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 120,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
