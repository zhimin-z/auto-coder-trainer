{
  "id": "recipe-exp21-reward-shaping-thinking",
  "name": "Exp 21: Reward shaping for thinking style (fast/slow/clever)",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-21"],
  "model": {
    "base": "Qwen/Qwen2.5-3B-Instruct",
    "size": "3B",
    "adapter": "full"
  },
  "dataset": {
    "sources": [
      {
        "name": "gsm8k",
        "path": "openai/gsm8k",
        "mix_weight": 1.0
      }
    ],
    "total_samples": 8000
  },
  "trainer": {
    "type": "grpo",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-6,
      "epochs": 3,
      "train_batch_size": 32,
      "ppo_mini_batch_size": 16,
      "ppo_micro_batch_size": 4,
      "ppo_epochs": 1,
      "max_prompt_length": 512,
      "max_response_length": 1024,
      "group_size": 8,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.001,
      "use_kl_loss": true,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.4,
      "rollout_tp_size": 1,
      "thinking_reward_style": "baseline",
      "custom_reward_function": "scripts/reward_thinking.py:compute_score"
    }
  },
  "ablation": [
    {
      "name": "thinking_reward_style",
      "variable": "trainer.params.thinking_reward_style",
      "values": ["baseline", "step_count_bonus", "step_count_penalty", "cleverness_bonus"]
    }
  ],
  "eval": {
    "benchmarks": [],
    "metrics": ["accuracy", "mean_steps", "mean_thinking_tokens", "method_diversity"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 96,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
