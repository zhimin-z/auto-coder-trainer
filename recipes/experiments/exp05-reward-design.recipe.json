{
  "id": "recipe-exp05-reward-design",
  "name": "Exp 05: Reward function design (binary vs partial vs process)",
  "version": "1.0",
  "source_papers": ["TinyZero_实验方案.md#实验-5"],
  "model": {
    "base": "Qwen/Qwen2.5-3B-Instruct",
    "size": "3B",
    "adapter": "full"
  },
  "dataset": {
    "sources": [
      {
        "name": "gsm8k",
        "path": "openai/gsm8k",
        "mix_weight": 1.0
      }
    ],
    "total_samples": 8000
  },
  "trainer": {
    "type": "grpo",
    "backend": "tinyzero",
    "params": {
      "lr": 1e-6,
      "epochs": 3,
      "train_batch_size": 32,
      "ppo_mini_batch_size": 16,
      "ppo_micro_batch_size": 4,
      "ppo_epochs": 1,
      "max_prompt_length": 512,
      "max_response_length": 1024,
      "group_size": 8,
      "temperature": 1.0,
      "top_p": 1.0,
      "kl_coeff": 0.001,
      "use_kl_loss": true,
      "gradient_checkpointing": true,
      "gpu_memory_utilization": 0.4,
      "rollout_tp_size": 1
    }
  },
  "ablation": [
    {
      "name": "reward_variant",
      "variable": "trainer.params.custom_reward_function",
      "values": [
        "binary",
        "scripts/reward_gsm8k_partial.py:compute_score",
        "scripts/reward_gsm8k_process.py:compute_score"
      ]
    }
  ],
  "eval": {
    "benchmarks": [],
    "metrics": ["reward_mean", "reasoning_steps_mean", "training_stability_cv"],
    "seeds": [42]
  },
  "budget": {
    "max_gpu_hours": 72,
    "gpu_type": "1xA100-80GB",
    "cuda_visible_devices": 7
  }
}
