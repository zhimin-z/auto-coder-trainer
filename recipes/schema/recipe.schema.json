{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Training Recipe",
  "description": "Structured intermediate representation for coding agent training experiments. Connects the ARIS Research Plane to the Training Plane.",
  "type": "object",
  "required": ["id", "name", "model", "dataset", "trainer"],
  "properties": {
    "id": { "type": "string", "description": "Unique recipe identifier (e.g., recipe-swe-fuse-sft-001)" },
    "name": { "type": "string", "description": "Human-readable recipe name" },
    "version": { "type": "string", "default": "1.0" },
    "source_papers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "arXiv IDs or DOIs of source papers"
    },
    "model": {
      "type": "object",
      "required": ["base"],
      "properties": {
        "base": { "type": "string", "description": "HuggingFace model ID" },
        "size": { "type": "string", "description": "Model size label (e.g., 7B, 32B)" },
        "adapter": { "enum": ["full", "lora", "qlora"], "default": "full" }
      }
    },
    "dataset": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "path"],
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string", "description": "HF dataset ID or local path" },
              "mix_weight": { "type": "number", "default": 1.0 }
            }
          }
        },
        "filters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "enum": ["issue_free", "length", "quality_score", "language", "custom"] },
              "params": { "type": "object" }
            }
          }
        },
        "total_samples": { "type": "integer" }
      }
    },
    "trainer": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["sft", "rl", "dpo", "grpo", "distill"] },
        "backend": { "enum": ["trl", "verl", "tinyzero", "openr1", "agent_distill", "redi", "swe_lego"], "default": "verl", "description": "Native backends: RL -> veRL, SFT/distill -> TRL. External upstream launchers: tinyzero, openr1, agent_distill, redi, swe_lego." },
        "params": { "type": "object", "description": "Training hyperparameters (lr, epochs, batch_size, ppo_epochs, rollout_batch_size, etc.)" },
        "reward": {
          "type": "object",
          "properties": {
            "type": { "enum": ["binary_pass", "weighted_pass", "entropy_bonus", "entropy_aware", "length_penalty", "composite"] },
            "components": { "type": "array", "items": { "type": "object" } }
          }
        }
      }
    },
    "distill": {
      "type": "object",
      "description": "Optional distillation configuration for teacher-trajectory or process distillation.",
      "properties": {
        "strategy": { "enum": ["trajectory", "process", "hybrid"], "default": "trajectory", "description": "Distillation strategy. 'trajectory': Implemented — train on teacher-generated traces. 'process': Not yet implemented — reserved for step-level distillation. 'hybrid': Not yet implemented — reserved for combined trajectory + process." },
        "teacher_model": { "type": "string", "description": "Teacher model identifier or descriptive label" },
        "teacher_mode": { "enum": ["offline_dataset", "local_model", "api"], "default": "offline_dataset" },
        "stages": {
          "type": "array",
          "items": { "enum": ["positive_sft", "pairwise_refine"] },
          "default": ["positive_sft"]
        },
        "refine_algorithm": { "enum": ["none", "dpo", "redi"], "default": "dpo" },
        "pairwise_beta": { "type": "number", "default": 0.1 },
        "trace_template": { "type": "string", "default": "chatml" },
        "upstream_repo": { "type": "string", "description": "Optional upstream repo URL override for external launcher backends" },
        "condense": {
          "type": "object",
          "properties": {
            "strategy": { "enum": ["none", "edge_preserving"], "default": "edge_preserving" },
            "max_chars": { "type": "integer", "default": 12000 },
            "head_chars": { "type": "integer", "default": 5000 },
            "tail_chars": { "type": "integer", "default": 5000 }
          }
        }
      }
    },
    "eval": {
      "type": "object",
      "properties": {
        "benchmarks": {
          "type": "array",
          "items": { "enum": ["swe-bench-lite", "swe-bench-verified", "swe-rebench", "humaneval", "mbpp", "mmlu", "hellaswag", "truthfulqa", "pass_at_k_gsm8k", "pass_at_k_math", "custom"] }
        },
        "metrics": { "type": "array", "items": { "type": "string" } },
        "seeds": { "type": "array", "items": { "type": "integer" }, "default": [42, 123, 456] }
      }
    },
    "ablation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "variable", "values"],
        "properties": {
          "name": { "type": "string" },
          "variable": { "type": "string", "description": "JSON path to the variable being ablated" },
          "values": { "type": "array" }
        }
      }
    },
    "budget": {
      "type": "object",
      "properties": {
        "max_gpu_hours": { "type": "number" },
        "gpu_type": { "type": "string" },
        "max_cost_usd": { "type": "number" },
        "cuda_visible_devices": {
          "description": "Pin training to specific GPU indices. Int (single GPU), array of ints, or comma-separated string. Written into the launcher's env.sh as CUDA_VISIBLE_DEVICES. Bypasses SLURM allocation when set.",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "array", "items": { "type": "integer", "minimum": 0 } },
            { "type": "string" }
          ]
        },
        "slurm": {
          "type": "object",
          "description": "SLURM job scheduler configuration for HPC execution.",
          "properties": {
            "partition": { "type": "string" },
            "qos": { "type": "string" },
            "nodes": { "type": "integer", "default": 1 },
            "gpus_per_node": { "type": "integer", "default": 1 },
            "cpus_per_task": { "type": "integer", "default": 16 },
            "mem": { "type": "string", "default": "256G" },
            "time": { "type": "string", "default": "72:00:00" },
            "account": { "type": "string" },
            "constraint": { "type": "string" },
            "modules": { "type": "array", "items": { "type": "string" } },
            "conda_env": { "type": "string" },
            "extra_sbatch": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
